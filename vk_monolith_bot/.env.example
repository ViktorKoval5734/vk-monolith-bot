# Токен сообщества ВКонтакте (получить можно тут: https://vk.com/apps?act=manage)
VK_TOKEN=your_vk_token_here

# ID сообщества ВКонтакте (числовой, без минуса)
VK_GROUP_ID=your_group_id_here

# Секретный ключ для Callback API (можно придумать любой)
CONFIRMATION_SECRET=your_secret_key_here

# Код подтверждения Callback API (ВКонтакте покажет при настройке)
VK_CONFIRMATION_CODE=your_confirmation_code_here

# API ключ YandexGPT (получить в Яндекс Облаке: https://cloud.yandex.ru/)
YANDEX_GPT_API_KEY=your_yandex_gpt_api_key_here

# ID папки в Яндекс Облаке
YANDEX_GPT_FOLDER_ID=your_folder_id_here

# Модель YandexGPT (по умолчанию: yandexgpt-lite)
YANDEX_GPT_MODEL=yandexgpt-lite

# Путь к файлу истории (опционально)
HISTORY_FILE=history.json
